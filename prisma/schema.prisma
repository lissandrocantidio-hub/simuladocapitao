generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String        @id @default(cuid())
  name         String
  email        String        @unique
  passwordHash String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  purchases    Purchase[]
  accessGrants AccessGrant[]
}

model Purchase {
  id                 String         @id @default(cuid())
  userId             String
  provider           PaymentProvider
  providerPaymentId  String?        @unique
  providerCheckoutId String?        @unique
  providerReference  String?        @unique
  status             PurchaseStatus @default(PENDING)
  amountCents        Int
  currency           String         @default("BRL")
  planCode           String
  metadata           Json?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  user               User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
}

model AccessGrant {
  id        String            @id @default(cuid())
  userId    String
  planCode  String
  status    AccessGrantStatus @default(ACTIVE)
  startsAt  DateTime
  expiresAt DateTime
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status, expiresAt])
}

model PaymentAccess {
  id                           String   @id @default(cuid())
  email                        String   @unique
  paymentId                    String?  @unique
  status                       String
  accessGranted                Boolean  @default(false)
  confirmationEmailSentAt      DateTime?
  confirmationEmailSentForPaymentId String?
  confirmationEmailLastError   String?
  createdAt                    DateTime @default(now())
  updatedAt                    DateTime @updatedAt
}

model MercadoPagoWebhookEvent {
  id         String   @id @default(cuid())
  topic      String?
  action     String?
  paymentId  String?
  email      String?
  rawPayload Json?
  createdAt  DateTime @default(now())

  @@index([paymentId, createdAt])
}

enum PaymentProvider {
  MERCADO_PAGO
}

enum PurchaseStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
  REFUNDED
}

enum AccessGrantStatus {
  ACTIVE
  EXPIRED
  REVOKED
}
